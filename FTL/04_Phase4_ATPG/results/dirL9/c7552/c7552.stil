Timing {
   WaveformTable "_default_WFT_" {
       Period '100ns';
       Waveforms {
           "CK" { 0 { '0ns' D; } }
           "CK" { P { '0ns' D; '50ns' U; '75ns' D; } }
           "CK" { 1 { '0ns' U; } }
           "CK" { Z { '0ns' Z; } }
           "_default_In_Timing_" { 0 { '0ns' D; } }
           "_default_In_Timing_" { 1 { '0ns' U; } }
           "_default_In_Timing_" { Z { '0ns' Z; } }
           "_default_In_Timing_" { N { '0ns' N; } }
           "_default_Out_Timing_" { X { '0ns' X; } }
           "_default_Out_Timing_" { H { '0ns' X; ' 90 ns' H; } }
           "_default_Out_Timing_" { T { '0ns' X; ' 90 ns' T; } }
           "_default_Out_Timing_" { L { '0ns' X; ' 90 ns' L; } }
       }
   }
}

ScanStructures {
   ScanChain "chain1" {
       ScanLength 0;
       ScanIn "test_si";
       ScanOut "test_so";
       ScanInversion 0;
       ScanCells;
       ScanMasterClock "CK" ;
   }
}

PatternBurst "_burst_" {
   PatList { "_pattern_" { } }
}

PatternExec {
   PatternBurst "_burst_";
}

Procedures {
   "load_unload" {
       W "_default_WFT_";
       C { "test_si"=0; "CK"=0; "test_se"=1; }
       V { "_so"=#; }
       Shift {
           W "_default_WFT_";
           V { "_si"=#; "_so"=#; "CK"=P; }
       }
   }
   "capture_CK" {
       W "_default_WFT_";
       F { "test_se"=0; }
       C { "_po"=\r63 X ; }
       "forcePI": V { "_pi"=\r208 # ; }
       "measurePO": V { "_po"=\r63 # ; }
       C { "_po"=\r63 X ; }
       "pulse": V { "CK"=P; }
   }
   "capture" {
       W "_default_WFT_";
       F { "test_se"=0; }
       C { "_po"=\r63 X ; }
       "forcePI": V { "_pi"=\r208 # ; }
       "measurePO": V { "_po"=\r63 # ; }
   }
}

MacroDefs {
   "test_setup" {
       W "_default_WFT_";
       V { "test_se"=0; "CK"=0; }
   }
}

Pattern "_pattern_" {
   W "_default_WFT_";
   "precondition all Signals": C { "_pi"=\r208 0 ; "_po"=\r63 X ; }
   Macro "test_setup";
   "pattern 0":
       Call "load_unload" {
           "test_si"=;
       }
       Call "capture_CK" {
           "_pi"=0000101101101101000000110001101101110100001000001100100000000101110001100110111001100011100011011110101100111001010101101100001111000100001101110101011111111011011101001000111010011001001010110100110110001011;
           "_po"=LHHHHHHHHHLLHLLHHLHLHLLLLHHLHLHHLLHLLHLHHHLHHHLLLLLLLLHLLLHLHHL;
       }
   "pattern 1":
       Call "load_unload" {
           "test_so"=;
           "test_si"=;
       }
       Call "capture_CK" {
           "_pi"=0000101101101101000000110001101101110100001000000110010100000001011100011001101110011000111100010111101011001110010101011011000011110001000011011101010111111110110111001011000011100110010010101101001101100011;
           "_po"=LHLHHHHHHHLLHHHHHLLLLLHHHHHHLLHHHHLHHHLLHHLHLLLHHLLHLHLHLHHHLLL;
       }
   "pattern 2":
       Call "load_unload" {
           "test_so"=;
           "test_si"=;
       }
       Call "capture_CK" {
           "_pi"=0000101101101101000000110001101101110100001000000011001100000001011100011001101110011000111110001011110101100111001010101101100001111000100001101110101011111111011011100100110001110011001001010110100110110001;
           "_po"=LHLHHHHHHHLHHHHHHLHHHLLLHHHHLHHHLLHHLHHLHHHLHHHLLHHLHLLHLHHLHLL;
       }
