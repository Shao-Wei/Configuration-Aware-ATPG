       }
   "pattern 1":
       Call "load_unload" {
           "test_so"=;
           "test_si"=;
       }
       Call "capture_CK" {
           "_pi"=00000110110101000000110001101101110100001000001100100000001011100011001101110011000111001011101011001011000101010001010101101110000111100000001011110000110111010101111111101101110;
           "_po"=LHLLLHHHHHHHHLLLLLLLLLLHHHLHLHHHLLHHHHHHHHLLLLLLLHLLLHHHHHHHHHHHLLHHHHLHHHHLLHLLLLLLLLHLLLHHHHHHH;
       }
   "pattern 2":
       Call "load_unload" {
           "test_so"=;
           "test_si"=;
