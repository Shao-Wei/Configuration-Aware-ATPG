STIL 1.0;

Signals {
   "CK" In;
   "test_si" In { ScanIn; }
   "test_se" In;
   "X" In;
   "Clear" In;
   "C_8" In;
   "C_7" In;
   "C_6" In;
   "C_5" In;
   "C_4" In;
   "C_3" In;
   "C_2" In;
   "C_1" In;
   "C_0" In;
   "Y_4" In;
   "Y_3" In;
   "Y_2" In;
   "Y_1" In;
   "Y_8" In;
   "Y_7" In;
   "Y_6" In;
   "Y_5" In;
   "test_so" Out { ScanOut; }
   "II6" Out;
   "II3" Out;
   "II4" Out;
   "II158" Out;
   "II155" Out;
   "II156" Out;
   "Z" Out;
   "II5" Out;
   "II157" Out;
   "W" Out;
}

SignalGroups {
   "_pi" = '"CK" + "test_si" + "test_se" + "X" + "Clear" + "C_8" + "C_7" + "C_6" + "C_5" + "C_4" + "C_3" + "C_2" + "C_1" + "C_0" + "Y_4" + "Y_3" + "Y_2" + "Y_1" + "Y_8" + "Y_7" + "Y_6" + "Y_5"';
   "_in" = '"CK" + "test_si" + "test_se" + "X" + "Clear" + "C_8" + "C_7" + "C_6" + "C_5" + "C_4" + "C_3" + "C_2" + "C_1" + "C_0" + "Y_4" + "Y_3" + "Y_2" + "Y_1" + "Y_8" + "Y_7" + "Y_6" + "Y_5"';
   "_si" = '"test_si"' { ScanIn; }
   "_po" = '"test_so" + "II6" + "II3" + "II4" + "II158" + "II155" + "II156" + "Z" + "II5" + "II157" + "W"';
   "_out" = '"test_so" + "II6" + "II3" + "II4" + "II158" + "II155" + "II156" + "Z" + "II5" + "II157" + "W"';
   "_so" = '"test_so"' { ScanOut; }
   "_default_In_Timing_" = '"test_si" + "test_se" + "X" + "Clear" + "C_8" + "C_7" + "C_6" + "C_5" + "C_4" + "C_3" + "C_2" + "C_1" + "C_0" + "Y_4" + "Y_3" + "Y_2" + "Y_1" + "Y_8" + "Y_7" + "Y_6" + "Y_5"';
   "_default_Out_Timing_" = '"test_so" + "II6" + "II3" + "II4" + "II158" + "II155" + "II156" + "Z" + "II5" + "II157" + "W"';
}

Timing {
   WaveformTable "_default_WFT_" {
       Period '100ns';
       Waveforms {
           "CK" { 0 { '0ns' D; } }
           "CK" { P { '0ns' D; '50ns' U; '75ns' D; } }
           "CK" { 1 { '0ns' U; } }
           "CK" { Z { '0ns' Z; } }
           "_default_In_Timing_" { 0 { '0ns' D; } }
           "_default_In_Timing_" { 1 { '0ns' U; } }
           "_default_In_Timing_" { Z { '0ns' Z; } }
           "_default_In_Timing_" { N { '0ns' N; } }
           "_default_Out_Timing_" { X { '0ns' X; } }
           "_default_Out_Timing_" { H { '0ns' X; ' 90 ns' H; } }
           "_default_Out_Timing_" { T { '0ns' X; ' 90 ns' T; } }
           "_default_Out_Timing_" { L { '0ns' X; ' 90 ns' L; } }
       }
   }
}

ScanStructures {
   ScanChain "chain1" {
       ScanLength 0;
       ScanIn "test_si";
       ScanOut "test_so";
       ScanInversion 0;
       ScanCells;
       ScanMasterClock "CK" ;
   }
}

PatternBurst "_burst_" {
   PatList { "_pattern_" { } }
}

PatternExec {
   PatternBurst "_burst_";
}

Procedures {
   "load_unload" {
       W "_default_WFT_";
       C { "test_si"=0; "CK"=0; "test_se"=1; }
       V { "_so"=#; }
       Shift {
           W "_default_WFT_";
           V { "_si"=#; "_so"=#; "CK"=P; }
       }
   }
   "capture_CK" {
       W "_default_WFT_";
       F { "test_se"=0; }
       C { "_po"=\r11 X ; }
       "forcePI": V { "_pi"=\r22 # ; }
       "measurePO": V { "_po"=\r11 # ; }
       C { "_po"=\r11 X ; }
       "pulse": V { "CK"=P; }
   }
   "capture" {
       W "_default_WFT_";
       F { "test_se"=0; }
       C { "_po"=\r11 X ; }
       "forcePI": V { "_pi"=\r22 # ; }
       "measurePO": V { "_po"=\r11 # ; }
   }
}

MacroDefs {
   "test_setup" {
       W "_default_WFT_";
       V { "test_se"=0; "CK"=0; }
   }
}

Pattern "_pattern_" {
   W "_default_WFT_";
   "precondition all Signals": C { "_pi"=\r22 0 ; "_po"=\r11 X ; }
   Macro "test_setup";
   "pattern 0":
       Call "load_unload" {
           "test_si"=;
       }
       Call "capture_CK" {
           "_pi"=0000011011010111110000;
           "_po"=LLLLHLLLLLL;
       }
   "pattern 1":
       Call "load_unload" {
           "test_so"=;
