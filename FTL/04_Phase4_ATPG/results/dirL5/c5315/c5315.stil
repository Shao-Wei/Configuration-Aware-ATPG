       }
   "pattern 1":
       Call "load_unload" {
           "test_so"=;
           "test_si"=;
       }
       Call "capture_CK" {
           "_pi"=00001101101010000001100011011011101000010000011001000000010111000110011011100110001110010111101011001110010101011011110001011000110111110001000011001010111101010111111111011011101;
           "_po"=LLLLLHHHHHHHHLLLLLLLLLLLLHHHHHHHLHHLHHLLHHLLLLHHLLHLLHHHLHHLLHHLLHLHLLLLHLLLLHLLHLLHHLLHHLLHHLHHH;
       }
   "pattern 2":
       Call "load_unload" {
           "test_so"=;
           "test_si"=;
