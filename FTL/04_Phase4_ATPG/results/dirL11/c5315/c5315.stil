       }
   "pattern 1":
       Call "load_unload" {
           "test_so"=;
           "test_si"=;
       }
       Call "capture_CK" {
           "_pi"=00001101101010000001100011011011101000010000011001000000010111000110011011100110001110010110011011011011001101111001101110011110001110110000101001100000100110110000100001101110101;
           "_po"=LLLLHHHHHHHHHLLLLLLLLLLHLLHLHLHHLHLHLLHHHHLLLLHHLHHHLLLLHHHHHLHLLHLHLHLLLHLHLHLLHLHLHLLLHLHHHHLHH;
       }
   "pattern 2":
       Call "load_unload" {
           "test_so"=;
           "test_si"=;
